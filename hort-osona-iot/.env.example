# =============================================================================
# Hort Osona - Variables d'entorn
# =============================================================================
#
# IMPORTANT: Aquest fitxer es la PLANTILLA. NO posis aqui el token real.
#
# Per configurar el teu entorn local:
#   1. Fes una copia: cp .env.example .env
#   2. Edita .env i posa els teus valors reals
#   3. .env ja esta al .gitignore, no es puja mai
#
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram Bot
# -----------------------------------------------------------------------------
# El token te el dona el @BotFather de Telegram quan fas /newbot
# Exemple: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_TOKEN=

# -----------------------------------------------------------------------------
# Ollama (IA local)
# -----------------------------------------------------------------------------
# Per defecte: http://localhost:11434
OLLAMA_HOST=http://localhost:11434

# Model a utilitzar (hermes3, llama3.1, etc.)
OLLAMA_MODEL=hermes3

# -----------------------------------------------------------------------------
# RaspBerry Pi (sensors IoT)
# -----------------------------------------------------------------------------
# URL del backend de la RPi (FastAPI)
# Per defecte: http://hortpi.local:8000
RPI_API_URL=http://hortpi.local:8000

# -----------------------------------------------------------------------------
# Opcions
# -----------------------------------------------------------------------------
# Nivell de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
